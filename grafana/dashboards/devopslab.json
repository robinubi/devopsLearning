{
  "title": "DevOps Lab — API Dashboard",
  "uid": "devopslab-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "graph",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P90 Latency (seconds)",
      "type": "graph",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p90 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "API Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "up{job='devopslab-api'}",
          "legendFormat": "API Up"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate (5xx)",
      "type": "graph",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total{code=~'5..'}[5m])",
          "legendFormat": "5xx errors/s"
        }
      ]
    }
  ]
}
